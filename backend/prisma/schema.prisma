generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./nimbusfs.db"
}

model User {
  id            Int      @id @default(autoincrement())
  username      String   @unique
  passwordHash  String
  role          String   @default("standard_user")
}

model FileMetadata {
  id            Int      @id @default(autoincrement())
  filename      String   
  size          Int
  owner         String   @default("Admin")
  locked        Boolean  @default(false)
  uploadDate    DateTime @default(now())
  nodeLocations String   
  isDeleted     Boolean  @default(false)
  unlockAt      DateTime?
}

model ActivityLog {
  id            Int      @id @default(autoincrement())
  timestamp     DateTime @default(now())
  action        String
  filename      String
  user          String   @default("Admin")
}

model SharedLink {
  id               Int      @id @default(autoincrement())
  filename         String
  token            String   @unique
  passwordHash     String?
  expiresAt        DateTime
  maxDownloads     Int      @default(100)
  currentDownloads Int      @default(0)
  createdAt        DateTime @default(now())
}

model Setting {
  key   String @id
  value String
}
